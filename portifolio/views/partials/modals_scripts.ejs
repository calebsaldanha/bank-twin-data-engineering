<div class="modal-overlay" id="modal-notebook">
    <div class="modal-content glass" style="max-width: 1200px; width: 95%; height: 90vh; padding: 1.5rem; display: flex; flex-direction: column;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; border-bottom: 1px solid var(--glass-border); padding-bottom: 10px;">
            <h3 id="notebook-title" style="font-family:'Space Grotesk'; font-size: 1.5rem; color: var(--text-main);">Notebook</h3>
            <button class="close-modal-btn" onclick="fecharModalNotebook()" style="background:none; border:none; color:var(--accent); font-size:2.5rem; cursor:pointer; line-height: 1;">&times;</button>
        </div>
        <iframe id="notebook-frame" src="" style="width: 100%; flex-grow: 1; border: none; border-radius: 8px; background: #fff;"></iframe>
    </div>
</div>

<script>
    function toggleTasks(targetId, iconId) {
        const tasksDiv = document.getElementById(targetId);
        const icon = document.getElementById(iconId);
        if (tasksDiv.style.display === 'none' || tasksDiv.style.display === '') {
            tasksDiv.style.display = 'block';
            icon.classList.remove('fa-chevron-down');
            icon.classList.add('fa-chevron-up');
        } else {
            tasksDiv.style.display = 'none';
            icon.classList.remove('fa-chevron-up');
            icon.classList.add('fa-chevron-down');
        }
    }
    
    function abrirModalNotebook(caminhoArquivo, titulo) {
        if (!caminhoArquivo) return;
        document.getElementById('notebook-title').innerText = "AED: " + titulo;
        document.getElementById('notebook-frame').src = caminhoArquivo;
        document.getElementById('modal-notebook').style.display = 'flex';
    }

    function fecharModalNotebook() {
        document.getElementById('modal-notebook').style.display = 'none';
        document.getElementById('notebook-frame').src = "";
        let selects = document.querySelectorAll('.notebook-select');
        selects.forEach(s => s.selectedIndex = 0);
    }

    function abrirHub(id) {
        document.querySelectorAll('#hub .article-detail').forEach(el => el.style.display = 'none');
        const target = document.getElementById(id);
        if(target) {
            target.style.display = 'block';
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            
            if(id === 'simulador-outliers' && !window.simLoaded) {
                initSimulator();
                window.simLoaded = true;
            }
        }
    }

    function fecharHub(id) {
        document.getElementById(id).style.display = 'none';
    }

    function initSimulator() {
        const simValues = [2000, 3000, 4000, 5000, 18000]; 
        const simMax = 20000;
        const simContainer = document.getElementById('sim-points-container');
        
        function updateSim() {
            let sorted = [...simValues].sort((a,b) => a - b);
            const sum = sorted.reduce((a,b) => a + b, 0);
            const mean = sum / sorted.length;
            const median = sorted[Math.floor(sorted.length / 2)];
            
            document.getElementById('sim-mean-val').innerText = mean.toLocaleString('pt-BR', {style: 'currency', currency: 'BRL'});
            document.getElementById('sim-median-val').innerText = median.toLocaleString('pt-BR', {style: 'currency', currency: 'BRL'});
            
            const meanPct = (mean / simMax) * 100;
            const medianPct = (median / simMax) * 100;
            
            document.getElementById('sim-mean-line').style.left = `${meanPct}%`;
            document.getElementById('sim-mean-label').style.left = `${meanPct}%`;
            
            document.getElementById('sim-median-line').style.left = `${medianPct}%`;
            document.getElementById('sim-median-label').style.left = `${medianPct}%`;
        }

        simContainer.innerHTML = '';
        simValues.forEach((val, index) => {
            const pt = document.createElement('div');
            pt.style.position = 'absolute';
            pt.style.width = '28px';
            pt.style.height = '28px';
            pt.style.background = 'var(--accent)'; 
            pt.style.borderRadius = '50%';
            pt.style.top = '50%';
            pt.style.transform = 'translate(-50%, -50%)';
            pt.style.cursor = 'grab';
            pt.style.border = '3px solid rgba(255,255,255,0.7)';
            pt.style.left = `${(val / simMax) * 100}%`;
            pt.style.touchAction = 'none'; // Evita zoom no mobile
            
            const ptLabel = document.createElement('div');
            ptLabel.style.position = 'absolute';
            ptLabel.style.top = '-30px';
            ptLabel.style.left = '50%';
            ptLabel.style.transform = 'translateX(-50%)';
            ptLabel.style.fontSize = '12px';
            ptLabel.style.color = 'var(--text-muted)';
            ptLabel.style.pointerEvents = 'none';
            pt.appendChild(ptLabel);

            let isDragging = false;
            
            const onDrag = (clientX) => {
                const rect = simContainer.getBoundingClientRect();
                let x = clientX - rect.left;
                let newPct = (x / rect.width) * 100;
                newPct = Math.max(0, Math.min(100, newPct));
                pt.style.left = `${newPct}%`;
                
                let newVal = (newPct / 100) * simMax;
                simValues[index] = newVal;
                ptLabel.innerText = Math.round(newVal/1000) + 'k';
                updateSim();
            };

            const startDrag = () => { 
                isDragging = true; 
                pt.style.cursor = 'grabbing'; 
                ptLabel.innerText = Math.round(simValues[index]/1000) + 'k'; 
            };
            
            const stopDrag = () => { 
                isDragging = false; 
                pt.style.cursor = 'grab'; 
                ptLabel.innerText = ''; 
            };

            // Eventos de Mouse (Desktop)
            pt.addEventListener('mousedown', startDrag);
            window.addEventListener('mousemove', (e) => { if(isDragging) onDrag(e.clientX); });
            window.addEventListener('mouseup', stopDrag);

            // Eventos de Toque (Mobile)
            pt.addEventListener('touchstart', (e) => { startDrag(); }, {passive: true});
            window.addEventListener('touchmove', (e) => { 
                if(isDragging) {
                    onDrag(e.touches[0].clientX); 
                    if (e.cancelable) e.preventDefault(); // Impede rolagem da tela
                }
            }, {passive: false});
            window.addEventListener('touchend', stopDrag);

            simContainer.appendChild(pt);
        });
        
        updateSim();
    }
</script>
<script src="assets/js/script.js?v=2"></script>
